---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {}
const props = Astro.props;
---

<div class="grid grid-cols-[1fr_min(calc(100%-1rem),72rem)_1fr] px-2 md:px-0">
	<slot name="left" />
	<div class="col-start-2">
		<div {...props}>
			<slot />
		</div>
	</div>
	<slot name="right" />
</div>
