---
import '@/styles/fonts.css';
import '@/styles/global.css';
import LatestStatus from '@client/statuses/LatestStatus.vue';

import BaseHead from '@components/base/BaseHead.astro';
import Footer from '@components/base/Footer.astro';
import Header from '@components/base/Header.astro';
import { container } from '@lib/classes';

interface Props {
    title?: string;
    description?: string;
}
---

<!doctype html>
<html lang="en" class="mocha">
    <head>
        <BaseHead {...Astro.props} />
        <slot name="head" />
    </head>
    <body
        class="min-h-dvh w-screen bg-linear-to-br from-ctp-mantle via-ctp-crust to-ctp-mantle selection:bg-ctp-pink selection:text-ctp-crust"
    >
        <div class="drop-shadow-md">
            <div class="grid grid-cols-5">
                <div class="h-4 bg-ctp-sapphire"></div>
                <div class="h-4 bg-ctp-pink"></div>
                <div class="h-4 bg-ctp-base latte"></div>
                <div class="h-4 bg-ctp-pink"></div>
                <div class="h-4 bg-ctp-sapphire"></div>
            </div>
        </div>

        <div class="h-full macchiato pt-3">
            <Header />

            <div class:list={[container, 'my-3']}>
                <LatestStatus client:load />
            </div>

            <div class="grid grid-cols-[1fr_min(calc(100%-1rem),72rem)_1fr] px-2 md:px-0">
                <slot name="left" />
                <main
                    class="bg-ctp-mantle p-3 rounded-lg border-2 border-dashed border-ctp-pink col-start-2"
                    transition:animate="fade"
                >
                    <slot />
                </main>
                <slot name="right" />
            </div>

            <Footer />
        </div>
    </body>
</html>
