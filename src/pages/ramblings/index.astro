---
import { getCollection } from 'astro:content';
import IconLink from '../../components/IconLink.astro';
import Page from '../../layouts/Page.astro';
import Rambling from '../../components/RamblingCard.astro';
import { RAMBLING_DESCRIPTION } from '../../consts';

const ramblings = (await getCollection('ramblings')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Page title="amelia's ramblings" description={RAMBLING_DESCRIPTION}>
    <div class="my-2">
        <IconLink text="view by tags" icon="label" url="/ramblings/tags/" />
    </div>
    <section>
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
            {[...ramblings].map(rambling => <Rambling rambling={rambling} />)}
        </ul>
    </section>
</Page>
