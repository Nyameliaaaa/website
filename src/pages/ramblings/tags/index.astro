---
import Page from '@layouts/Page.astro';
import { body, link } from '@lib/classes';
import { getCollection } from 'astro:content';

const ramblings = await getCollection('ramblings');
const tags = [...new Set(ramblings.flatMap(p => p.data.tags))];
---

<Page title="amelia's ramblings" description="a full list of all tags that exist :P">
    <section>
        <ul class="mt-4 list-disc list-inside">
            {
                tags.map(tag => (
                    <li class={`${body} ${link}`}>
                        <a href={`/ramblings/tags/${tag}`}>{tag}</a>
                    </li>
                ))
            }
        </ul>
    </section>
</Page>
