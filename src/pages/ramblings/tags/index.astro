---
import Tag from '@components/rambling/Tag.astro';
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';

const ramblings = await getCollection('ramblings');
const tags = [...new Set(ramblings.flatMap(p => p.data.tags))];
---

<Page title="amelia's ramblings" description="a full list of all tags that exist :P">
	<section>
		<ul class="flex flex-row flex-wrap gap-2 my-4">
			{tags.map(tag => <Tag tag={tag ?? ''} />)}
		</ul>
	</section>
</Page>
