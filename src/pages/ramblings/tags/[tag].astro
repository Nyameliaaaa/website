---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import Rambling from "../../../components/Rambling.astro";

export async function getStaticPaths() {
	const ramblings = await getCollection("ramblings");
	const tags = [...new Set(ramblings.flatMap((p) => p.data.tags))];
	return tags.map((tag) => ({
		params: { tag },
		props: {
			tag,
			posts: ramblings.filter(
				(p) => p.data.tags && p.data.tags.includes(tag ?? ""),
			),
		},
	}));
}

const { tag, posts, ...props } = Astro.props;
---

<Base title={`amelia's ${tag} ramblings`}>
	<section>
		<ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
			{[...posts].map((rambling) => <Rambling rambling={rambling} />)}
		</ul>
	</section>
</Base>
