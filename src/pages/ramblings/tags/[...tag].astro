---
import Rambling from "@components/rambling/RamblingCard.astro";
import Page from "@layouts/Page.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
	const ramblings = await getCollection("ramblings");
	const tags = [
		...new Set(ramblings.flatMap((rambling) => rambling.data.tags)),
	];
	return tags.map((tag) => ({
		params: { tag },
		props: {
			tag,
			ramblings: ramblings.filter(
				(rambling) =>
					rambling.data.tags &&
					rambling.data.tags.includes(tag ?? ""),
			),
		},
	}));
}

const { tag, ramblings } = Astro.props;
---

<Page title={`amelia's ${tag} ramblings`}>
	<section>
		<ul class="flex flex-col gap-2">
			{ramblings.map((rambling) => <Rambling rambling={rambling} />)}
		</ul>
	</section>
</Page>
