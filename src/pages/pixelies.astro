---
import { type PixelieEntry } from '@/types';
import { Image } from 'astro:assets';
import Page from '../layouts/Page.astro';

interface Gallery {
    name: string;
    pixelies: PixelieEntry[];
}

const pixelies: Gallery[] = [
    {
        name: 'gf <3',
        pixelies: [
            {
                url: 'https://gayspace.fr',
                img: 'https://gayspace.fr/images/buttons/button.gif',
                alt: 'lori <3'
            }
        ]
    },
    {
        name: 'website inspo',
        pixelies: [
            {
                url: 'https://sapphic.moe',
                img: 'https://sapphic.moe/buttons/sapphic.png',
                alt: 'sapphic angels'
            },
            {
                url: 'https://maia.crimew.gay',
                img: 'https://maia.crimew.gay/badges/maia.crimew.gay.png',
                alt: 'maia arson crimew'
            }
        ]
    }
];
---

<Page title="the museum" description="a wall of 88x31's, obviously">
    <div class="flex flex-col divide-y-2 divide-ctp-base">
        {
            pixelies.map(pixelie => (
                <section class="py-3">
                    <h2 class="text-ctp-pink font-bold text-xl mb-2">{pixelie.name}</h2>
                    <ul class="flex flex-row gap-2 font-medium">
                        {pixelie.pixelies.map(pixelie => (
                            <li>
                                {pixelie.url ? (
                                    <a href={pixelie.url}>
                                        <Image
                                            src={pixelie.img}
                                            width="88"
                                            height="31"
                                            alt={pixelie.alt ?? ''}
                                            style="image-rendering: pixelated;"
                                        />
                                    </a>
                                ) : (
                                    <Image
                                        src={pixelie.img}
                                        width="88"
                                        height="31"
                                        alt={pixelie.alt ?? ''}
                                        style="image-rendering: pixelated;"
                                    />
                                )}
                            </li>
                        ))}
                    </ul>
                </section>
            ))
        }
    </div>
</Page>
