---
import IconLink from '@components/link/IconLink.astro';
import PixelieImg from '@components/link/PixelieImg.astro';
import WrapLink from '@components/link/WrapLink.astro';
import { caption, link } from '@lib/classes';
import { footerPixelies, footerUrls } from '@lib/data';
import { version } from 'vue';
---

<footer>
	<div class="grid grid-cols-1 md:grid-cols-2 items-start gap-2">
		<div class="flex flex-col gap-3">
			<div>
				<p class={caption}>
					&copy; copyright 2017-{new Date().getFullYear()} amelia isabel rose
				</p>
				<p class={caption}>
					article content (ramblings) licensed under <WrapLink
						href="https://creativecommons.org/licenses/by-nc/4.0/"
						class={link}
					>
						CC BY-NC 4.0</WrapLink
					>
				</p>
			</div>

			<div>
				<p class={caption}>
					{Astro.generator.replace('A', 'a')}, vue v{version}
				</p>
				<p class={caption}>
					commit <WrapLink
						href={`https://git.gay/nyamelia/website/commit/${import.meta.env.CF_PAGES_COMMIT_SHA}`}
						class={link}>{import.meta.env.CF_PAGES_COMMIT_SHA}</WrapLink
					>
				</p>
				<p class={caption}>
					tested using <WrapLink href="https://firefox.com" class={link}> firefox</WrapLink>
				</p>
			</div>

			<ul class="flex flex-row gap-2 max-md:hidden">
				{footerPixelies.map(pixelie => <PixelieImg pixelie={pixelie} />)}
			</ul>
		</div>
		<div>
			<div class="grid grid-cols-2 lg:grid-cols-2 xl:gap-3 select-none">
				{
					footerUrls.map(url => (
						<div class="mb-2">
							<IconLink {...url} />
						</div>
					))
				}
			</div>
			<ul class="mt-2 flex flex-row gap-2 md:hidden">
				{footerPixelies.map(pixelie => <PixelieImg pixelie={pixelie} />)}
			</ul>
		</div>
	</div>
</footer>
