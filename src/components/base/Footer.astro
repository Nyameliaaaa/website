---
import IconLink from '@components/link/IconLink.astro';
import PixelieImg from '@components/link/PixelieImg.astro';
import { caption, text } from '@lib/classes';
import { footerPixelies, footerUrls } from '@lib/data';
---

<footer>
    <div class="grid grid-cols-1 md:grid-cols-2 select-none">
        <div class="flex flex-col gap-2 items-left justify-between">
            <div class="group flex flex-row gap-2 transition-all duration-400 items-center">
                <p class={caption}>
                    made with <span class={text({ color: 'accent', weight: 'medium' })}>{'<3'}</span> and <span
                        class={text({ color: 'accent', weight: 'medium' })}>:3</span
                    > by amelia
                </p>
            </div>
            <div class="grid grid-cols-2 lg:grid-cols-2 xl:gap-3">
                {
                    footerUrls.map((url, index) => (
                        <div class="mb-2">
                            <IconLink {...url} />
                        </div>
                    ))
                }
            </div>
        </div>
        <ul class="flex flex-row flex-wrap justify-start gap-2">
            {footerPixelies.map(pixelie => <PixelieImg pixelie={pixelie} />)}
        </ul>
    </div>
</footer>
